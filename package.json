{
  "name": "discord-youtube-music-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:activity && tsc",
    "build:activity": "vite build",
    "dev": "tsx watch src/index.ts",
    "dev:activity": "vite",
    "deploy": "tsx src/deploy-commands.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.5.0",
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "hls.js": "^1.6.16",
    "opusscript": "^0.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.2"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
